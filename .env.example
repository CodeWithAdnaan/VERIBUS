# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env.local and fill in from your Supabase project
#   Supabase Dashboard → Project Settings → API      (URL + anon + service_role)
#   Supabase Dashboard → Project Settings → Database  (Connection string, "URI")
# ─────────────────────────────────────────────────────────────────────────────

# Public (browser) — safe to expose
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Server-only — NEVER expose to the browser. Used by the ingest path + migration scripts.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Direct Postgres connection (for scripts/db-push, seed, demo-reset).
# Use the "Session" pooler / direct URI. Include ?sslmode=require if needed.
SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres

# Server-side secret used to sign/verify the in-bus QR bind HMAC fallback.
# (Per-vehicle bind_secret lives in the DB; this is only a defense-in-depth pepper.)
BIND_HMAC_PEPPER=change-me-in-production

# Optional: shared secret the Vercel cron sends to /api/cron/watchdog
CRON_SECRET=change-me
